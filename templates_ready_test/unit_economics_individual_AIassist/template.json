  "experiment_config": {
    "arms": [
      "fully_automatic_ai",
      "individual_plus_ai",
      "team_plus_ai"
    ],
    "individual_arm_team_size": 1,
    "team_arm_team_size": 4,
    "hypothesis": "Fully-Automatic AI \u2248 Individual+AI, and Team+AI adds no measurable gain. A within-system, verifiable calculation has one right answer reachable by AI alone, so there is no decomposition or divergence advantage for a team.",
    "primary_outcome": "total_score (0-100)",
    "mechanism_outcomes": [
      "objective_correctness",
      "decision_verifiability"
    ]
  },
  "lens_assignments": [
    {
      "member_slot": 1,
      "lens": "Whole calculation",
      "goal": "Compute every figure; in the Team arm members cross-check the same numbers (no division of labor helps)."
