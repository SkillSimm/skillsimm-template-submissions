{
  "additionalProperties": false,
  "description": "One step's grading rule. Field requirements per type are enforced by the\nvalidator (spec \u00a74 decision tree), not here, so issues come back as\nreadable findings instead of a pydantic stack.",
  "properties": {
    "type": {
      "enum": [
        "answer_key",
        "rubric",
        "numeric",
        "llm_judge",
        "none"
      ],
      "title": "Type",
      "type": "string"
    },
    "points": {
      "default": 1,
      "title": "Points",
      "type": "number"
    },
    "options": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Options"
    },
    "correct_answer": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Correct Answer"
    },
    "distractors": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Distractors"
    },
    "expected_value": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Expected Value"
    },
    "expected_range": {
      "anyOf": [
        {
          "items": {
            "type": "number"
          },
          "maxItems": 2,
          "minItems": 2,
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Expected Range"
    },
    "tolerance": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tolerance"
    },
    "formula": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Formula"
    },
    "criteria": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Criteria"
    },
    "anchor_examples": {
      "anyOf": [
        {
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Anchor Examples"
    }
  },
  "required": [
    "type"
  ],
  "title": "GradingRule",
  "type": "object"
}